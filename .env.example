# Application
APP_NAME=SentinelAI API
APP_VERSION=0.1.0
APP_ENV=development
DEBUG=false
API_V1_PREFIX=/api/v1
CORS_ALLOWED_ORIGINS=http://localhost:5173

# PostgreSQL
POSTGRES_DB=sentinelai
POSTGRES_USER=sentinelai
POSTGRES_PASSWORD=change-me-for-local-development

# Backend database
DATABASE_URL=postgresql+psycopg://sentinelai:change-me-for-local-development@database:5432/sentinelai

# Authentication
JWT_SECRET_KEY=replace-with-a-long-random-development-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
ACCESS_TOKEN_COOKIE_NAME=sentinelai_access_token
COOKIE_SECURE=false
COOKIE_SAMESITE=lax
COOKIE_PATH=/

# Frontend
VITE_API_BASE_URL=http://localhost:8000
